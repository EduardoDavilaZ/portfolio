---
import type { Translations } from '../i18n';
import { contactInfo } from '../config/contact';

interface Props {
    t: Translations['contact'];
}

const { t } = Astro.props;
---

<div class="modal fade" id="contactModal" tabindex="-1" aria-labelledby="contactModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content contact-modal">
            <div class="modal-header border-0 pb-0">
                <h2 class="modal-title section-title" id="contactModalLabel">{t.title}</h2>
                <button type="button" class="btn-close btn-close-themed" data-bs-dismiss="modal" aria-label={t.close}></button>
            </div>
            <div class="modal-body pt-3">
                <p class="contact-intro">{t.subtitle}</p>

                <ul class="contact-list">
                    <li>
                        <a href={`mailto:${contactInfo.email}`} class="contact-link">
                            <i class="fa-solid fa-envelope"></i>
                            <span>
                                <strong>{t.email}</strong>
                                {contactInfo.email}
                            </span>
                        </a>
                    </li>
                    <li>
                        <a href={`tel:${contactInfo.phone}`} class="contact-link">
                            <i class="fa-solid fa-phone"></i>
                            <span>
                                <strong>{t.phone}</strong>
                                {contactInfo.phoneDisplay}
                            </span>
                        </a>
                    </li>
                    <li>
                        <span class="contact-link contact-static">
                            <i class="fa-solid fa-location-dot"></i>
                            <span>
                                <strong>{t.location}</strong>
                                {contactInfo.location}
                            </span>
                        </span>
                    </li>
                </ul>

                <div class="contact-actions">
                    <a href={contactInfo.linkedin} target="_blank" rel="noopener noreferrer" class="btn btn-outline-theme btn-sm">
                        <i class="fa-brands fa-linkedin-in"></i>
                        LinkedIn
                    </a>
                    <a href={contactInfo.github} target="_blank" rel="noopener noreferrer" class="btn btn-outline-theme btn-sm">
                        <i class="fa-brands fa-github"></i>
                        GitHub
                    </a>
                    <a href={contactInfo.cvUrl} download class="btn btn-contact btn-sm">
                        <i class="fa-solid fa-file-arrow-down"></i>
                        {t.downloadCv}
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .contact-modal {
        background: var(--id-bg-superficie);
        border: 1px solid var(--id-border-color);
        border-radius: 20px;
        color: var(--id-text-primary);
    }

    .contact-intro {
        color: var(--id-text-secondary);
        margin-bottom: 1.25rem;
        line-height: 1.6;
    }

    .contact-list {
        list-style: none;
        padding: 0;
        margin: 0 0 1.5rem;
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
    }

    .contact-link {
        display: flex;
        align-items: flex-start;
        gap: 0.85rem;
        padding: 0.85rem 1rem;
        border-radius: 12px;
        background: var(--id-surface-overlay);
        border: 1px solid var(--id-border-color);
        color: var(--id-text-primary);
        text-decoration: none;
        transition: border-color 0.3s ease, transform 0.2s ease;

        &:hover {
            border-color: var(--id-color-brand);
            transform: translateY(-2px);
            color: var(--id-text-primary);
        }

        i {
            color: var(--id-color-brand);
            font-size: 1.1rem;
            margin-top: 0.15rem;
            width: 1.25rem;
            text-align: center;
        }

        span {
            display: flex;
            flex-direction: column;
            gap: 0.15rem;
            font-size: 0.95rem;
        }

        strong {
            color: var(--id-text-secondary);
            font-size: 0.75rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.04em;
        }
    }

    .contact-static {
        cursor: default;

        &:hover {
            transform: none;
        }
    }

    .contact-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem;
    }

    .btn-close-themed {
        filter: none;
        opacity: 0.7;
    }

    :global([data-bs-theme="dark"]) .btn-close-themed {
        filter: invert(1) grayscale(100%) brightness(200%);
    }
</style>
