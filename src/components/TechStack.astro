---
import type { Translations } from '../i18n';

interface Props {
    t: Translations['techStack'];
}

const { t } = Astro.props;
---

<article class="bento-card">
    <h2 class="section-title">
        <i class="fas fa-layer-group text-brand me-2"></i>{t.title}
    </h2>

    <div class="tech-group">
        <span class="group-label">{t.groups.backend}</span>
        <div class="tech-badges">
            <span class="t-badge"><i class="fab fa-laravel"></i> Laravel</span>
            <span class="t-badge"><i class="fab fa-php"></i> PHP</span>
            <span class="t-badge"><i class="fas fa-box-open"></i> Composer</span>
            <span class="t-badge"><i class="fas fa-layer-group"></i> Eloquent</span>
            <span class="t-badge"><i class="fas fa-network-wired"></i> API REST</span>
            <span class="t-badge"><i class="fab fa-java"></i> Java</span>
            <span class="t-badge"><i class="fa-solid fa-copyright"></i> C</span>
        </div>
    </div>

    <div class="tech-group">
        <span class="group-label">{t.groups.frontend}</span>
        <div class="tech-badges">
            <span class="t-badge"><i class="fab fa-html5"></i> HTML5</span>
            <span class="t-badge"><i class="fab fa-css3-alt"></i> CSS3</span>
            <span class="t-badge"><i class="fab fa-bootstrap"></i> Bootstrap</span>
            <span class="t-badge"><i class="fab fa-js"></i> JavaScript</span>
            <span class="t-badge"><i class="fas fa-code"></i> TypeScript</span>
            <span class="t-badge"><i class="fas fa-rocket"></i> Astro</span>
            <span class="t-badge"><i class="fab fa-figma"></i> Figma</span>
        </div>
    </div>

    <div class="tech-group">
        <span class="group-label">{t.groups.databases}</span>
        <div class="tech-badges">
            <span class="t-badge"><i class="fas fa-database"></i> MySQL</span>
            <span class="t-badge"><i class="fas fa-server"></i> SQL Server</span>
        </div>
    </div>

    <div class="tech-group">
        <span class="group-label">{t.groups.workflow}</span>
        <div class="tech-badges">
            <span class="t-badge"><i class="fas fa-sync"></i> Scrum</span>
            <span class="t-badge"><i class="fas fa-bolt"></i> Agile</span>
            <span class="t-badge"><i class="fas fa-columns"></i> Kanban</span>
            <span class="t-badge"><i class="fab fa-git-alt"></i> Git</span>
            <span class="t-badge"><i class="fab fa-github"></i> GitHub</span>
            <span class="t-badge"><i class="fas fa-tasks"></i> Jira</span>
        </div>
    </div>
</article>

<style>
    .group-label {
        color: var(--id-text-secondary);
        font-size: 0.7rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1px;
        display: block;
        margin-bottom: 0.8rem;
    }

    .tech-badges {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        margin-bottom: 1.5rem;
    }

    .t-badge i {
        font-size: 0.9rem;
    }
</style>
